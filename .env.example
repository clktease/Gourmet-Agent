# ============================================================
# Fake Review Filter Agent - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ---- SerpAPI (Google Maps reviews) ----
# Get your key at https://serpapi.com/manage-api-key
SERP_API_KEY=your_serpapi_key_here

# ---- OpenAI (review classification) ----
OPENAI_API_KEY=your_openai_api_key_here
CLASSIFIER_MODEL=gpt-5.2

# ---- Pipeline tuning ----
# Reviews sent to the LLM per classification call
CLASSIFY_BATCH_SIZE=10
# Concurrent classification calls in flight
CLASSIFY_CONCURRENCY=3
# How many restaurants to analyze in parallel when running a batch report
BUSINESS_CONCURRENCY=2
# Default cap on reviews fetched per business
MAX_REVIEWS_DEFAULT=100
